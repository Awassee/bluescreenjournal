{
  "vault_path": "/Users/you/Documents/BlueScreenJournal",
  "sync_target_path": "/Users/you/Library/Mobile Documents/com~apple~CloudDocs/BlueScreenJournal",
  "sync_backend_preference": "folder",
  "gdrive_folder_id": "appDataFolder",
  "dropbox_root": "/BlueScreenJournal-Sync",
  "local_device_id": null,
  "device_nickname": "This Mac",
  "typewriter_mode": false,
  "clock_12h": false,
  "show_seconds": false,
  "show_ruler": true,
  "show_footer_legend": true,
  "soundtrack_source": "https://www.midi-karaoke.info/21b56501.mid",
  "opening_line_template": "JOURNAL ENTRY {DATE}",
  "daily_word_goal": 500,
  "remember_passphrase_in_keychain": false,
  "search_presets": [
    {
      "name": "Weekly Review",
      "query": "focus",
      "from": "2026-03-01",
      "to": "2026-03-07"
    }
  ],
  "backup_retention": {
    "daily": 7,
    "weekly": 4,
    "monthly": 6
  },
  "macros": [
    {
      "key": "ctrl-j",
      "type": "insert_template",
      "text": "TODAY I NOTICED:\n\n"
    },
    {
      "key": "ctrl-d",
      "type": "command",
      "command": "insert_date_header"
    },
    {
      "key": "ctrl-o",
      "type": "command",
      "command": "insert_closing_line"
    },
    {
      "key": "ctrl-g",
      "type": "command",
      "command": "jump_today"
    }
  ]
}
